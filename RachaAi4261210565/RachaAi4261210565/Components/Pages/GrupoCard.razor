@page "/grupo"
@using RachaAi4261210565.Models

<div class="grupo-card @(Grupo.NoVermelho ? "card-danger" : "card-success")">
    <div class="grupo-card-left">
        <span class="categoria-badge">
            @GetCategoriaIcon() @Grupo.Categoria
        </span>
        <strong class="grupo-nome">@Grupo.Nome</strong>
    </div>
    <div class="grupo-card-right">
        <span class="status-label @(Grupo.NoVermelho ? "text-danger" : "text-success")">
            @(Grupo.NoVermelho ? "Você deve" : "Você recebe")
        </span>
        <span class="valor @(Grupo.NoVermelho ? "text-danger" : "text-success")">
            @Grupo.ValorPendente.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
        </span>
    </div>
</div>

@code {
    [Parameter] public Grupo Grupo { get; set; } = new();

    private string GetCategoriaIcon() => Grupo.Categoria.ToLower() switch
    {
        "casa" => "🏠",
        "lazer" => "🎉",
        "viagem" => "✈️",
        "contas" => "💡",
        "comida" => "🍔",
        "mercado" => "🛒",
        _ => "📦"
    };
}
