@page "/dashboard"
@using RachaAi4261210565.Models

<PageTitle>RachaAí | Dashboard</PageTitle>

<div class="dashboard-wrapper">

    <!-- Header -->
    <div class="dash-header">
        <div>
            <h1 class="saudacao">Olá, Daniel! <span class="wave">👋</span></h1>
            <p class="subtitulo">Aqui está o resumo das suas finanças coletivas</p>
        </div>
        <button class="btn-fab" @onclick="AbrirNovoGasto">
            <span class="fab-icon">＋</span> Novo Gasto
        </button>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <div class="stat-card stat-saldo">
                <div class="stat-label">Saldo Geral</div>
                <div class="stat-valor">@SaldoGeral.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</div>
                <div class="stat-icon">💰</div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="stat-card stat-receber">
                <div class="stat-label">A Receber</div>
                <div class="stat-valor">@TotalReceber.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</div>
                <div class="stat-icon">📥</div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="stat-card stat-pagar">
                <div class="stat-label">A Pagar</div>
                <div class="stat-valor">@TotalPagar.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</div>
                <div class="stat-icon">📤</div>
            </div>
        </div>
    </div>

    <!-- Busca -->
    <div class="busca-wrapper mb-4">
        <span class="busca-icon">🔍</span>
        <input class="busca-input"
               type="text"
               placeholder="Buscar grupo ou categoria..."
               @bind-value="termoBusca"
               @bind-value:event="oninput" />
    </div>

    <!-- Lista de Grupos -->
    <div class="grupos-section">
        <h2 class="section-title">SEUS GRUPOS ATIVOS</h2>

        @if (!GruposFiltrados.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🫗</div>
                <p class="empty-msg">
                    @if (string.IsNullOrEmpty(termoBusca))
                    {
                        <span>Você ainda não participa de nenhum grupo.<br /><strong>Que tal criar um?</strong></span>
                    }
                    else
                    {
                        <span>Nenhum grupo encontrado para "<strong>@termoBusca</strong>".</span>
                    }
                </p>
            </div>
        }
        else
        {
            @foreach (var grupo in GruposFiltrados)
            {
                <GrupoCard Grupo="grupo" />
            }
        }
    </div>
</div>

<!-- Estilos -->
<style>
    :root {
        --brand-primary: #6C63FF;
        --brand-secondary: #48CFAD;
        --brand-danger: #FC5C65;
        --bg-page: #F0F2F8;
        --bg-card: #FFFFFF;
        --text-main: #1A1D2E;
        --text-muted: #8892A4;
        --radius-lg: 18px;
        --radius-md: 12px;
        --shadow-card: 0 4px 24px rgba(108,99,255,0.10);
        --shadow-hover: 0 8px 32px rgba(108,99,255,0.18);
    }

    body, .dashboard-wrapper {
        background: var(--bg-page);
        font-family: 'Segoe UI', 'Nunito', sans-serif;
        color: var(--text-main);
    }

    .dashboard-wrapper {
        max-width: 860px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
    }

    /* Header */
    .dash-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .saudacao {
        font-size: 2rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.5px;
        color: var(--text-main);
    }

    .wave { display: inline-block; animation: wave 1.8s infinite; transform-origin: 70% 70%; }
    @@keyframes wave {
        0%,100% { transform: rotate(0deg); }
        20%      { transform: rotate(20deg); }
        40%      { transform: rotate(-10deg); }
        60%      { transform: rotate(14deg); }
        80%      { transform: rotate(-5deg); }
    }

    .subtitulo {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin: 0.25rem 0 0;
    }

    /* FAB */
    .btn-fab {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--brand-primary);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 0.65rem 1.4rem;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(108,99,255,0.35);
        transition: transform 0.15s, box-shadow 0.15s;
        white-space: nowrap;
    }

    .btn-fab:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(108,99,255,0.45);
    }

    .fab-icon { font-size: 1.2rem; font-weight: 300; }

    /* Stat Cards */
    .stat-card {
        position: relative;
        overflow: hidden;
        border-radius: var(--radius-lg);
        padding: 1.4rem 1.5rem;
        color: #fff;
        box-shadow: var(--shadow-card);
        transition: transform 0.2s;
    }

    .stat-card:hover { transform: translateY(-3px); }

    .stat-saldo   { background: linear-gradient(135deg, #6C63FF 0%, #A78BFA 100%); }
    .stat-receber { background: linear-gradient(135deg, #11998e 0%, #48CFAD 100%); }
    .stat-pagar   { background: linear-gradient(135deg, #FC5C65 0%, #F7971E 100%); }

    .stat-label {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: 0.85;
        margin-bottom: 0.4rem;
    }

    .stat-valor {
        font-size: 1.65rem;
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    .stat-icon {
        position: absolute;
        right: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 2.4rem;
        opacity: 0.2;
    }

    /* Busca */
    .busca-wrapper {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: var(--bg-card);
        border: 2px solid transparent;
        border-radius: var(--radius-md);
        padding: 0.65rem 1.1rem;
        box-shadow: var(--shadow-card);
        transition: border-color 0.2s;
    }

    .busca-wrapper:focus-within {
        border-color: var(--brand-primary);
    }

    .busca-icon { font-size: 1rem; }

    .busca-input {
        flex: 1;
        border: none;
        outline: none;
        font-size: 0.95rem;
        background: transparent;
        color: var(--text-main);
    }

    .busca-input::placeholder { color: var(--text-muted); }

    /* Section title */
    .section-title {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 2px;
        color: var(--text-muted);
        margin-bottom: 0.75rem;
    }

    /* Grupo Cards */
    .grupo-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--bg-card);
        border-radius: var(--radius-md);
        padding: 1rem 1.25rem;
        margin-bottom: 0.75rem;
        box-shadow: var(--shadow-card);
        border-left: 4px solid transparent;
        transition: transform 0.18s, box-shadow 0.18s;
        cursor: pointer;
    }

    .grupo-card:hover {
        transform: translateX(4px);
        box-shadow: var(--shadow-hover);
    }

    .card-danger  { border-left-color: var(--brand-danger); }
    .card-success { border-left-color: var(--brand-secondary); }

    .grupo-card-left {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .categoria-badge {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--text-muted);
        letter-spacing: 0.5px;
        text-transform: capitalize;
    }

    .grupo-nome {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-main);
    }

    .grupo-card-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.15rem;
    }

    .status-label {
        font-size: 0.72rem;
        font-weight: 500;
    }

    .valor {
        font-size: 1rem;
        font-weight: 800;
    }

    .text-danger  { color: var(--brand-danger) !important; }
    .text-success { color: #11998e !important; }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--text-muted);
    }

    .empty-icon { font-size: 3rem; margin-bottom: 0.75rem; }
    .empty-msg  { font-size: 1rem; line-height: 1.6; }
</style>

@code {
    private string termoBusca = string.Empty;

    private List<Grupo> grupos = new()
    {
        new Grupo { Nome = "República Central",    Categoria = "Casa",    ValorPendente = 450.50m,   NoVermelho = true  },
        new Grupo { Nome = "Churrasco de Domingo", Categoria = "Lazer",   ValorPendente = 85.00m,    NoVermelho = false },
        new Grupo { Nome = "Viagem Floripa",        Categoria = "Viagem",  ValorPendente = 1200.00m,  NoVermelho = false },
        new Grupo { Nome = "Netflix & Internet",    Categoria = "Contas",  ValorPendente = 35.90m,    NoVermelho = true  },
    };

    private IEnumerable<Grupo> GruposFiltrados =>
        string.IsNullOrWhiteSpace(termoBusca)
            ? grupos
            : grupos.Where(g =>
                g.Nome.Contains(termoBusca, StringComparison.OrdinalIgnoreCase) ||
                g.Categoria.Contains(termoBusca, StringComparison.OrdinalIgnoreCase));

    private decimal TotalReceber => grupos.Where(g => !g.NoVermelho).Sum(g => g.ValorPendente);
    private decimal TotalPagar   => grupos.Where(g =>  g.NoVermelho).Sum(g => g.ValorPendente);
    private decimal SaldoGeral   => TotalReceber - TotalPagar;

    private void AbrirNovoGasto() { /* navegar para formulário */ }
}
